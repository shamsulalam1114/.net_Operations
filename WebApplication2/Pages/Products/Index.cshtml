@page
@model YourAppNamespace.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Product List";
}

<div class="container mt-4">
    <h1>Product List</h1>

    <div class="row mt-4">
        <div class="col-md-12">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Price</th>
                        <th>Category</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model.Products)
                    {
                        <tr>
                            <td>
                                <a asp-page="./Details" asp-route-id="@product.Id">
                                    @product.Name
                                </a>
                            </td>
                            <td>$@product.Price.ToString("N2")</td>
                            <td>@product.Category</td>
                            <td>
                                <a asp-page="./Details" asp-route-id="@product.Id" class="btn btn-primary btn-sm">
                                    View Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>