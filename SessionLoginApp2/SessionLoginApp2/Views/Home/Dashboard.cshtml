@model SessionLoginApp2.DTOs.UserDTO

@{
    ViewData["Title"] = "Dashboard";
}

<h2>Welcome to Your Dashboard</h2>

<div class="card mt-3" style="max-width: 400px;">
    <div class="card-header">
        <strong>Your Profile</strong>
    </div>
    <div class="card-body">
        <table class="table">
            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
        </table>
    </div>
</div>

<a asp-controller="Account" asp-action="Logout" class="btn btn-danger mt-3">Logout</a>
